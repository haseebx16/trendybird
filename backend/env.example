# ===========================================
# TrendyBird Backend — Environment Variables
# Copy this file as .env and fill in real values
# ===========================================

# Server
NODE_ENV=development
PORT=3000

# Supabase (use the legacy anon key approach)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# API Keys (server-side only — NEVER expose to client)
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# RevenueCat (server-side secret key)
REVENUECAT_API_KEY=your_revenuecat_secret_api_key
REVENUECAT_WEBHOOK_SECRET=your_webhook_auth_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cron
CRON_ENABLED=true
CRON_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=info

# Cache TTL (seconds)
CACHE_TTL_TRENDS=900
CACHE_TTL_SCORES=1800
